<div class="modal fade" id="bookModal" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content"><div class="modal-header" style="background:linear-gradient(135deg,#667eea,#764ba2);color:white"><h5 class="modal-title" id="bookTitle"></h5><button class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body" id="bookContent"><div class="text-center py-5"><div class="spinner-border"></div><p class="text-muted mt-2">加载教材内容...</p></div></div></div></div></div>
<style>.book-card:hover{transform:translateY(-3px);box-shadow:0 8px 25px rgba(0,0,0,.12)!important}</style>
<script>
async function viewBook(name,edition,author,pages,icon,color,hasPages){
    document.getElementById('bookTitle').innerHTML=`${icon} ${name} <small class="text-white-50">${edition} · ${pages}页</small>`;
    document.getElementById('bookContent').innerHTML=`<div class="text-center py-5"><div class="spinner-border"></div><p class="text-muted mt-2">加载中...</p></div>`;
    new bootstrap.Modal(document.getElementById('bookModal')).show();

    let html=`<div class="p-3 mb-3 rounded" style="background:linear-gradient(135deg,${color}22,${color}11);border-left:4px solid ${color}"><h5>${icon} ${name} (${edition})</h5><p class="mb-1">作者: ${author||'人民卫生出版社'}</p><p class="mb-0 small">📄 共 ${pages} 页 · 人民卫生出版社</p></div>`;

    if(!hasPages){
        html+=`<div class="alert alert-info small">📭 该教材的页面提取数据暂不可用。<br>请通过 <strong>管理后台→📤上传教材</strong> 上传PDF/Word文件，系统将自动提取文本并生成页面预览。</div>`;
        document.getElementById('bookContent').innerHTML=html;return;
    }

    try{
        let resp=await fetch(`/api/textbook/pages?name=${encodeURIComponent(name)}`);
        if(!resp.ok){html+=`<div class="alert alert-warning small">⚠️ 加载失败: HTTP ${resp.status}</div>`;document.getElementById('bookContent').innerHTML=html;return;}
        let data=await resp.json();
        if(data.error){html+=`<div class="alert alert-warning small">⚠️ ${data.error}</div>`;document.getElementById('bookContent').innerHTML=html;return;}
        html+=`<div class="alert alert-success small">📖 已提取 ${data.total} 页 · 显示前${data.preview.length}页</div><div class="accordion" id="pageAcc">`;
        data.preview.forEach((p,i)=>{
            let txt=(p.t||'').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            // compress long text
            let short=txt.length>300?txt.substring(0,300)+'...':txt;
            html+=`<div class="accordion-item"><h2 class="accordion-header"><button class="accordion-button collapsed small py-1" data-bs-toggle="collapse" data-bs-target="#pp${i}" style="font-size:.75rem">📄 第${p.n}页 <span class="ms-2 text-muted">${short.substring(0,60).replace(/&lt;/g,'<').replace(/&gt;/g,'>')}...</span></button></h2><div id="pp${i}" class="accordion-collapse collapse" data-bs-parent="#pageAcc"><div class="accordion-body small" style="white-space:pre-wrap;max-height:300px;overflow-y:auto;font-size:.75rem;line-height:1.6">${txt}</div></div></div>`;
        });
        html+=`</div>`;
        if(data.has_more) html+=`<p class="text-muted small mt-2">仅显示前50页预览，共${data.total}页</p>`;
    }catch(e){
        html+=`<div class="alert alert-danger small">❌ 加载出错: ${e.message}</div>`;
    }
    document.getElementById('bookContent').innerHTML=html;
}
</script>

