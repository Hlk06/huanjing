    <main class="container mt-4 mb-5">
        
            
        

        
<div class="mb-2"><h5 class="fw-bold mb-0">📝 智能记事本</h5><small class="text-muted">语音输入 · 代办清单 · 知识点记录 · 错题归纳</small></div>
<div class="row g-2 mb-3">
 <div class="col-6 col-md-3"><button class="btn w-100 btn-outline-primary btn-sm" onclick="switchTab('todo')" id="tabBtnTodo">✅ 代办</button></div>
 <div class="col-6 col-md-3"><button class="btn w-100 btn-outline-info btn-sm" onclick="switchTab('note')" id="tabBtnNote">📒 笔记</button></div>
 <div class="col-6 col-md-3"><button class="btn w-100 btn-outline-warning btn-sm" onclick="switchTab('error')" id="tabBtnError">❌ 错题</button></div>
 <div class="col-6 col-md-3"><button class="btn w-100 btn-outline-success btn-sm" id="voiceBtn" onclick="toggleVoice()">🎤 录音</button></div>
</div>
<div id="voiceBar" style="display:none;" class="alert alert-info mb-2 py-1 small text-center">🔴 正在聆听... <span id="voiceText"></span> <button class="btn btn-sm btn-outline-secondary ms-2" onclick="stopVoice()">停止</button></div>
<div id="tabTodo"><div class="input-group input-group-sm mb-2"><input class="form-control" id="todoInput" placeholder="添加代办..." onkeydown="if(event.key==='Enter')addTodo()"><button class="btn btn-primary" onclick="addTodo()">+</button></div><div id="todoList"></div></div>
<div id="tabNote" style="display:none;"><div class="mb-2"><textarea class="form-control form-control-sm" id="noteInput" rows="8" placeholder="记录知识点... 支持Markdown"></textarea></div><div class="d-flex gap-1 mb-2"><button class="btn btn-sm btn-primary" onclick="saveNote()">💾 保存笔记</button><button class="btn btn-sm btn-outline-secondary" onclick="clearNote()">清空</button></div><div id="noteList"></div></div>
<div id="tabError" style="display:none;"><div class="input-group input-group-sm mb-2"><input class="form-control" id="errorQ" placeholder="题目..."><input class="form-control" id="errorA" placeholder="正确答案..."><button class="btn btn-warning" onclick="addError()">+ 错题</button></div><div id="errorList"></div></div>
<script>
// Storage keys
const STORAGE={todo:'np_todos',note:'np_notes',error:'np_errors'};
function load(k){try{return JSON.parse(localStorage.getItem(k)||'[]')}catch(e){return[]}}
function save(k,v){localStorage.setItem(k,JSON.stringify(v))}
// Tab switch
let currentTab='todo';
function switchTab(t){currentTab=t;['todo','note','error'].forEach(x=>{document.getElementById('tab'+x.charAt(0).toUpperCase()+x.slice(1)).style.display=x===t?'block':'none';document.getElementById('tabBtn'+x.charAt(0).toUpperCase()+x.slice(1)).classList.toggle('active',x===t)});if(t==='todo')renderTodos();if(t==='note')renderNotes();if(t==='error')renderErrors();}
// Todos
function addTodo(){const v=document.getElementById('todoInput').value.trim();if(!v)return;const todos=load(STORAGE.todo);todos.push({id:Date.now(),text:v,done:false,time:new Date().toLocaleString()});save(STORAGE.todo,todos);document.getElementById('todoInput').value='';renderTodos();}
function toggleTodo(id){const todos=load(STORAGE.todo);const t=todos.find(x=>x.id===id);if(t)t.done=!t.done;save(STORAGE.todo,todos);renderTodos();}
function delTodo(id){const todos=load(STORAGE.todo).filter(x=>x.id!==id);save(STORAGE.todo,todos);renderTodos();}
function renderTodos(){const todos=load(STORAGE.todo);document.getElementById('todoList').innerHTML=todos.length===0?'<p class="text-muted small">暂无代办</p>':todos.map(t=>`<div class="d-flex align-items-center border-bottom py-1 small"><input type="checkbox" ${t.done?'checked':''} onchange="toggleTodo(${t.id})" class="me-2"><span class="flex-grow-1" style="${t.done?'text-decoration:line-through;color:#999':''}">${t.text}</span><small class="text-muted me-1">${t.time}</small><button class="btn btn-sm text-danger" onclick="delTodo(${t.id})">×</button></div>`).join('');}
// Notes
function saveNote(){const v=document.getElementById('noteInput').value.trim();if(!v)return;const notes=load(STORAGE.note);notes.unshift({id:Date.now(),content:v,time:new Date().toLocaleString()});if(notes.length>50)notes.length=50;save(STORAGE.note,notes);document.getElementById('noteInput').value='';renderNotes();}
function clearNote(){document.getElementById('noteInput').value='';}
function delNote(id){const notes=load(STORAGE.note).filter(x=>x.id!==id);save(STORAGE.note,notes);renderNotes();}
function renderNotes(){const notes=load(STORAGE.note);document.getElementById('noteList').innerHTML=notes.length===0?'<p class="text-muted small">暂无笔记</p>':notes.map(n=>`<div class="border rounded p-2 mb-1 bg-light"><div class="small" style="white-space:pre-wrap">${n.content}</div><div class="d-flex justify-content-between mt-1"><small class="text-muted">${n.time}</small><button class="btn btn-sm text-danger" onclick="delNote(${n.id})">×</button></div></div>`).join('');}
// Errors
function addError(){const q=document.getElementById('errorQ').value.trim();const a=document.getElementById('errorA').value.trim();if(!q||!a)return;const errors=load(STORAGE.error);errors.unshift({id:Date.now(),question:q,answer:a,time:new Date().toLocaleString(),reviewed:0});save(STORAGE.error,errors);document.getElementById('errorQ').value='';document.getElementById('errorA').value='';renderErrors();}
function delError(id){const errors=load(STORAGE.error).filter(x=>x.id!==id);save(STORAGE.error,errors);renderErrors();}
function reviewError(id){const errors=load(STORAGE.error);const e=errors.find(x=>x.id===id);if(e)e.reviewed=(e.reviewed||0)+1;save(STORAGE.error,errors);renderErrors();}
function renderErrors(){const errors=load(STORAGE.error);document.getElementById('errorList').innerHTML=errors.length===0?'<p class="text-muted small">暂无错题</p>':errors.map(e=>`<div class="border rounded p-2 mb-1"><div class="small fw-bold">📝 ${e.question}</div><div class="small text-success">✅ ${e.answer}</div><div class="d-flex justify-content-between mt-1"><small class="text-muted">${e.time} · 复习${e.reviewed||0}次</small><div><button class="btn btn-sm btn-outline-info me-1" onclick="reviewError(${e.id})">复习</button><button class="btn btn-sm text-danger" onclick="delError(${e.id})">×</button></div></div></div>`).join('');}
// Voice
let recognition=null;
function toggleVoice(){if(!('webkitSpeechRecognition' in window)&&!('SpeechRecognition' in window)){alert('您的浏览器不支持语音识别，请使用Chrome浏览器');return}if(recognition){stopVoice();return}const SR=window.SpeechRecognition||window.webkitSpeechRecognition;recognition=new SR();recognition.lang='zh-CN';recognition.interimResults=true;recognition.continuous=true;recognition.onresult=e=>{let txt='';for(let i=e.resultIndex;i<e.results.length;i++)txt+=e.results[i][0].transcript;document.getElementById('voiceText').textContent=txt;};recognition.onend=()=>{const txt=document.getElementById('voiceText').textContent;if(txt&&currentTab==='note'){document.getElementById('noteInput').value+=(document.getElementById('noteInput').value?'\n':'')+txt;}else if(txt&&currentTab==='todo'){document.getElementById('todoInput').value=txt;}document.getElementById('voiceText').textContent='';document.getElementById('voiceBar').style.display='none';document.getElementById('voiceBtn').textContent='🎤 录音';recognition=null;};recognition.start();document.getElementById('voiceBar').style.display='block';document.getElementById('voiceBtn').textContent='⏹️ 停止';}
function stopVoice(){if(recognition){recognition.stop();recognition=null;}document.getElementById('voiceBar').style.display='none';document.getElementById('voiceBtn').textContent='🎤 录音';}
// Init
renderTodos();
</script>

