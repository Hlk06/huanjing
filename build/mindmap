    <div class="d-flex gap-1">
        <select class="form-select form-select-sm" id="sysSelect" style="width:auto;"><option value="">全部系统</option><option value="1" >❤️ 循环系统</option><option value="2" >🫁 呼吸系统</option><option value="3" >🔬 消化系统</option><option value="4" >💧 泌尿系统</option><option value="5" >⚡ 内分泌系统</option><option value="6" >🧠 神经系统</option><option value="7" >🛡️ 免疫系统</option><option value="8" >🧬 生殖系统</option><option value="9" >🦴 运动系统</option></select>
