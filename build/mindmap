<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
let graphData=null,svg=null,simulation=null,selectedNode=null;
const W=()=>document.getElementById('graphContainer').clientWidth;
const H=()=>document.getElementById('graphContainer').clientHeight;

function buildGraph(raw){let nodes=[],links=[];nodes.push({id:'root',name:'医学知识',group:0,size:20,type:'root'});
raw.forEach(s=>{let sid='s'+s.id;nodes.push({id:sid,name:s.name,group:1,size:14,type:'system',sysId:s.id,icon:s.icon||'📋'});
links.push({source:'root',target:sid,value:1});
s.diseases.forEach(d=>{let did='d'+d.id;nodes.push({id:did,name:d.name,group:2,size:8,type:'disease',diseaseId:d.id,sysName:s.name});
links.push({source:sid,target:did,value:1});});});
return{nodes,links};}

async function loadGraph(){
    const sid=document.getElementById('sysSelect').value;
    const url=sid?`/api/systems/${sid}/diseases`:'/api/systems';
    const resp=await fetch('/api/systems');
    const systems=await resp.json();
    let all=[];
    if(sid){const dr=await fetch(`/api/systems/${sid}/diseases`);const dx=await dr.json();all=[{id:parseInt(sid),name:dx.length>0?dx[0].system_name:'',diseases:dx}];}
    else{for(let s of systems){if(s.id>9)continue;const dr=await fetch(`/api/systems/${s.id}/diseases`);const dx=await dr.json();all.push({id:s.id,name:s.name,diseases:dx});}}
    graphData=buildGraph(all.filter(s=>s.diseases.length>0));render();}

function render(){
    d3.select('#graphContainer').selectAll('*').remove();
    const w=W(),h=H();svg=d3.select('#graphContainer').append('svg').attr('width',w).attr('height',h);
    const g=svg.append('g');
    const zoom=d3.zoom().scaleExtent([0.2,5]).on('zoom',e=>{g.attr('transform',e.transform);});
    svg.call(zoom);
    const color=d3.scaleOrdinal(['#e74c3c','#3498db','#2ecc71','#f39c12','#9b59b6','#1abc9c','#e91e63','#ff9800','#607d8b']);
    simulation=d3.forceSimulation(graphData.nodes).force('link',d3.forceLink(graphData.links).id(d=>d.id).distance(100)).force('charge',d3.forceManyBody().strength(-300)).force('center',d3.forceCenter(w/2,h/2)).force('collision',d3.forceCollide().radius(d=>d.size*1.5));
    const link=g.append('g').selectAll('line').data(graphData.links).enter().append('line').attr('class','link').attr('stroke-width',d=>Math.sqrt(d.value));
    const node=g.append('g').selectAll('g').data(graphData.nodes).enter().append('g').attr('class','node').call(d3.drag().on('start',(e,d)=>{if(!e.active)simulation.alphaTarget(0.3).restart();d.fx=d.x;d.fy=d.y;}).on('drag',(e,d)=>{d.fx=e.x;d.fy=e.y;}).on('end',(e,d)=>{if(!e.active)simulation.alphaTarget(0);d.fx=null;d.fy=null;}));
    node.append('circle').attr('r',d=>d.size).attr('fill',d=>color(d.group)).attr('stroke','#fff').attr('stroke-width',2);
    node.append('text').text(d=>d.name.length>8?d.name.slice(0,8)+'..':d.name).attr('dx',d=>d.size+4).attr('dy',4);
    node.append('title').text(d=>d.name);
    node.on('click',(e,d)=>{e.stopPropagation();if(d.type==='disease')showDetail(d);});
    node.on('dblclick',(e,d)=>{if(d.type==='disease')window.open('/disease/'+d.diseaseId,'_blank');});
    simulation.on('tick',()=>{link.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y).attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);node.attr('transform',d=>`translate(${d.x},${d.y})`);});
}
function showDetail(d){selectedNode=d;fetch(`/api/diseases/${d.diseaseId}`).then(r=>r.json()).then(data=>{document.getElementById('detailTitle').textContent=d.name;let html=`<small class='text-muted'>系统: ${d.sysName}</small><p class='mt-2'>${data.overview||'无概述'}</p>`;if(data.infos){for(let[k,v]of Object.entries(data.infos)){if(v&&v.length>0){let typeNames={definition:'📖 定义',pathogenesis:'🔄 发病机制',pathology:'🔬 病理',clinical_diagnosis:'📋 诊断',prevention:'🛡️ 预防',treatment:'💊 治疗',prognosis:'📈 预后',examination:'🔍 检查',staging:'📊 分期',differential_diagnosis:'⚖️ 鉴别'};let label=typeNames[k]||k;html+=`<div class='p-2 mt-1 bg-light rounded small'><strong>${label}:</strong> ${v[0].content.slice(0,120)}...</div>`;}}}document.getElementById('detailContent').innerHTML=html;document.getElementById('nodeDetail').style.display='block';});}
function closeDetail(){document.getElementById('nodeDetail').style.display='none';selectedNode=null;}
function editNode(){if(!selectedNode)return;window.open('/disease/'+selectedNode.diseaseId,'_blank');closeDetail();}
function deleteNode(){if(!selectedNode)return;if(!confirm(`确定要删除"${selectedNode.name}"? 此操作不可撤销!`))return;fetch(`/api/diseases/${selectedNode.diseaseId}`,{method:'DELETE'}).then(r=>r.json()).then(d=>{alert(d.message||'已删除');closeDetail();setTimeout(loadGraph,500);});}
function resetZoom(){svg.transition().duration(500).call(d3.zoom().transform,d3.zoomIdentity);}
document.getElementById('sysSelect')?.addEventListener('change',loadGraph);
loadGraph();
</script>

</body>
